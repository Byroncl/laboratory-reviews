# Database
MONGODB_URI=mongodb://localhost:27017/post-message

# App
APP_NAME=Post Message API
HOST=localhost
PORT=3000
NODE_ENV=development

# Auth
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# Seed Configuration
# Set SEED_ENABLED=true to run the seeder on startup
SEED_ENABLED=false
SEED_CLEAR=true
SEED_USERS=5
SEED_POSTS=3
SEED_COMMENTS=5
SEED_REACTIONS=3
